# Postgres for better-auth tables (same Neon instance as the counter is fine — the
# counter owns projects/api_keys, the dashboard owns the auth tables). Local dev: a
# local Postgres or a Neon branch. Run `pnpm db:push` once to create the auth tables.
DATABASE_URL=postgresql://...

# better-auth: >=32-char high-entropy secret. Generate: `openssl rand -base64 32`.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3001

# Invite-only signup. Comma-separated exact emails and/or `@domain` entries. Unset =>
# open signup (fine for local dev). PROD MUST SET THIS or anyone can create an account.
# e.g. SIGNUP_ALLOWLIST=you@studioapp.co,@studioapp.co,partner@acme.com
SIGNUP_ALLOWLIST=

# The counter control-plane API. The dashboard is a BFF over it: it holds ADMIN_TOKEN
# server-side and scopes every call to the logged-in user. Start it with `pnpm counter`.
BISMITE_API_URL=http://localhost:4000
# Must match the counter's ADMIN_TOKEN. Unset on both sides = open issuance (local dev).
ADMIN_TOKEN=
