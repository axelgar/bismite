# Postgres for better-auth tables (same Neon instance as the counter is fine — the
# counter owns projects/api_keys, the dashboard owns the auth tables). Local dev: a
# local Postgres or a Neon branch. Run `pnpm db:push` once to create the auth tables.
DATABASE_URL=postgresql://...

# better-auth: >=32-char high-entropy secret. Generate: `openssl rand -base64 32`.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3001

# Invite-only signup. Comma-separated exact emails and/or `@domain` entries. Unset =>
# open signup (fine for local dev). PROD MUST SET THIS or anyone can create an account.
# e.g. SIGNUP_ALLOWLIST=you@studioapp.co,@studioapp.co,partner@acme.com
SIGNUP_ALLOWLIST=

# The counter control-plane API. The dashboard is a BFF over it: it holds ADMIN_TOKEN
# server-side and scopes every call to the logged-in user. Start it with `pnpm counter`.
BISMITE_API_URL=http://localhost:4000
# Must match the counter's ADMIN_TOKEN. Unset on both sides = open issuance (local dev).
ADMIN_TOKEN=

# Stripe billing. Unset => billing OFF: the Upgrade button is disabled, no paid plans. The
# Pro subscription is PER-ORG (v2/B): one €19 base + an optional metered MTU-overage line.
# - STRIPE_SECRET_KEY: sk_test_… (test mode) / sk_live_… in prod.
# - STRIPE_PRICE_PRO: the recurring Price id for the €19 Pro base (price_…).
# - STRIPE_WEBHOOK_SECRET: whsec_… for the /api/stripe/webhook endpoint signature check.
#   Local: `stripe listen --forward-to localhost:3001/api/stripe/webhook` prints it.
STRIPE_SECRET_KEY=
STRIPE_PRICE_PRO=
STRIPE_WEBHOOK_SECRET=

# Usage-based MTU overage (v2/B #8) — €8 per 1,000 MTU above the included 10,000. Create these
# ONCE in the Stripe console (test AND live), then paste the ids:
#   1. Billing > Meters > new Meter, event name `mtu_overage`, aggregation = Sum.
#   2. A usage-based Price linked to that Meter, package pricing €8 per 1,000 units (so the
#      reconcile's per-MTU `value` bills at €0.008 each).
# Unset => flat Pro tier, no overage (the reconcile cron is inert).
STRIPE_PRICE_MTU_OVERAGE=
STRIPE_METER_MTU_OVERAGE=mtu_overage
# Bearer secret for the daily overage reconcile cron (/api/cron/reconcile-overage). Vercel
# cron sends it; set the same value in the Vercel cron config. Unset => route open (dev only).
CRON_SECRET=
