# Vercel builds this standalone app with npm. better-auth's drizzle-adapter declares a
# peerOptional on drizzle-orm@^0.45.2, but we pin 0.38.x to match the counter — and the
# adapter runs fine on it (verified end-to-end). npm's strict peer check would otherwise
# fail the build; pnpm (local) already tolerates the optional peer.
legacy-peer-deps=true
