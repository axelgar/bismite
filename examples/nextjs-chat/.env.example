# Copy to .env.local and fill with your Stripe TEST values (sk_test_... / whsec_...).
# Get the price ID from a TEST subscription Product in the Stripe dashboard.

# Hosted counter (default): one key, no second vendor. Mint a key against a running
# counter service: `pnpm counter` then `pnpm issue-key`, paste the test key here.
BISMITE_API_KEY=bsk_test_...
BISMITE_API_URL=http://localhost:4000

# BYO escape hatch (no lock-in): set BISMITE_COUNTER=upstash + your own Redis to
# meter check/record there instead of the hosted counter.
# BISMITE_COUNTER=upstash
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PRICE_PRO=price_xxx

# Printed by: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=whsec_xxx
